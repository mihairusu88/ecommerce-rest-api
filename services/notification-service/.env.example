PORT=3005

# Kafka (optional). Leave KAFKA_BROKERS unset to run in mock mode: no user events
# are consumed. Set it (comma-separated host:port list) to subscribe to the
# `user-events` topic (published by auth-service) and react to UserLoggedIn /
# UserDetailed — see docker-compose.yml.
# KAFKA_BROKERS=localhost:9092
# KAFKA_CLIENT_ID=notification-service
# KAFKA_GROUP_ID=notification-service-group
# KAFKA_USER_EVENTS_TOPIC=user-events
