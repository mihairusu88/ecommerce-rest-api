PORT=3006

# Kafka (optional). Leave KAFKA_BROKERS unset to run in mock mode: analytics
# serves only its seeded event log. Set it (comma-separated host:port list) to
# subscribe to the `user-events` topic (published by auth-service) and record
# UserLoggedIn / UserDetailed as analytics events — see docker-compose.yml.
# KAFKA_BROKERS=localhost:9092
# KAFKA_CLIENT_ID=analytics-service
# KAFKA_GROUP_ID=analytics-service-group
# KAFKA_USER_EVENTS_TOPIC=user-events
