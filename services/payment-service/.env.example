PORT=3004

# Kafka (optional). Leave KAFKA_BROKERS unset to run in mock mode: payments are
# created only via POST /api/payments. Set it (comma-separated host:port list) to
# subscribe to the `orders` topic (published by order-service) and open a pending
# payment for each placed order — see docker-compose.yml.
# KAFKA_BROKERS=localhost:9092
# KAFKA_CLIENT_ID=payment-service
# KAFKA_GROUP_ID=payment-service-group
# KAFKA_ORDERS_TOPIC=orders
