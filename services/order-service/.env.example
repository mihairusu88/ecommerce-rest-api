PORT=3003

# Kafka (optional). Leave KAFKA_BROKERS unset to run in mock mode: orders are
# still created, but no OrderPlaced event is published. Set it (comma-separated
# host:port list) to publish to the `orders` topic — see docker-compose.yml.
# KAFKA_BROKERS=localhost:9092
# KAFKA_CLIENT_ID=order-service
# KAFKA_ORDERS_TOPIC=orders
