PORT=3001

# Secret used to sign/verify JWT access tokens. Use a long random value in prod.
JWT_SECRET=dev-secret-change-me
# Access token lifetime (any value accepted by jsonwebtoken, e.g. 15m, 1h, 7d).
JWT_EXPIRES_IN=1h

# Separate secret for refresh tokens (falls back to JWT_SECRET + "-refresh").
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
# Refresh token lifetime.
JWT_REFRESH_EXPIRES_IN=7d

# Kafka (optional). Leave KAFKA_BROKERS unset to run in mock mode: login/me work
# but no user-event is published. Set it (comma-separated host:port list) to
# publish UserLoggedIn / UserDetailed to the `user-events` topic — see
# docker-compose.yml.
# KAFKA_BROKERS=localhost:9092
# KAFKA_CLIENT_ID=auth-service
# KAFKA_USER_EVENTS_TOPIC=user-events
