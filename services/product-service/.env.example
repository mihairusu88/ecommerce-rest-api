PORT=3002

# Kafka (optional). Leave KAFKA_BROKERS unset to run in mock mode: the catalogue
# is read-only and no OrderPlaced events are consumed. Set it (comma-separated
# host:port list) to subscribe to the `orders` topic and decrement stock on each
# order — see docker-compose.yml.
# KAFKA_BROKERS=localhost:9092
# KAFKA_CLIENT_ID=product-service
# KAFKA_GROUP_ID=product-service-inventory
# KAFKA_ORDERS_TOPIC=orders
